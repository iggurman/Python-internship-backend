# Take a string and print the frequency of each character.
# Example:
# Input: banana

# Output:
# b = 1
# a = 3
# n = 2

string1=input("Enter String")
freq={}
for char in string1:
    if char in freq:
        freq[char]+=1
    else:
        freq[char]=1
for key,value in freq.items():
    print(f"{key}={value}")